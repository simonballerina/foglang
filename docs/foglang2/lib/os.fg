boul os_get_kernel() {
    tpos "touch foglang_temp_kernel.txt";
    tpos "printf %s $(uname) > foglang_temp_kernel.txt";

    band slip kernel = "foglang_temp_kernel.txt";


    givet att kernel = "Linux" eller kernel = "Darwin" eller kernel = "FreeBSD" {
        tpos "rm foglang_temp_kernel.txt";
        return kernel;
    }

    return "NT";
}
